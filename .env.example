# Embedding Configuration
# Options: auto, openai, openai-legacy, vertex, local
# - auto: Selects openai → vertex → local based on available credentials
# - openai: Use OpenAI text-embedding-3-small (recommended for production)
# - openai-legacy: Use OpenAI text-embedding-ada-002 (legacy)
# - vertex: Use Google Vertex AI text-embedding-004 (requires GCP project)
# - local: Use sentence-transformers (free, no API key needed)
EMBEDDING_MODE=auto

# OpenAI API Key (required for openai and openai-legacy modes)
OPENAI_API_KEY=your-openai-api-key-here

# Environment (development or production)
# - development: Defaults to local embeddings when EMBEDDING_MODE=auto
# - production: Defaults to OpenAI embeddings when EMBEDDING_MODE=auto
ENVIRONMENT=development

# ── Vertex AI Embeddings ──────────────────────────────────────────────────────
# Required when EMBEDDING_MODE=vertex (or auto with no OPENAI_API_KEY).
#
# IAM: The identity running this app needs roles/aiplatform.user on the project.
#   gcloud projects add-iam-policy-binding YOUR_PROJECT_ID \
#     --member="serviceAccount:YOUR_SA@YOUR_PROJECT_ID.iam.gserviceaccount.com" \
#     --role="roles/aiplatform.user"
#
# Auth: Use Application Default Credentials (preferred) or a key file.
#   Local dev: run `gcloud auth application-default login`
#   CI/prod:   set GOOGLE_APPLICATION_CREDENTIALS to a service-account key path
#              OR attach a service account to the compute instance / Cloud Run job.

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Which Vertex AI embedding model to use.
# Options: text-embedding-004 (English), text-multilingual-embedding-002 (100+ languages)
VERTEX_EMBEDDING_MODEL=text-embedding-004

# Path to a GCP service-account key file (only needed when ADC is unavailable).
# Leave unset when running on GCE / GKE / Cloud Run — the attached SA is used automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
